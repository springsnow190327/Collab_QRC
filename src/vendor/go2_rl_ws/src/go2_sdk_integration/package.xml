<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>go2_sdk_integration</name>
  <version>0.0.0</version>
  <description>Unitree sdk ROS integration package.</description>
  <maintainer email="gabearod2@gmail.com">gabriel</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- All find_package()'d deps must be declared here so colcon orders
       their installs before this package builds. Missing entries caused a
       race where CMakeLists.txt's find_package(unitree_api REQUIRED) fired
       before unitree_api's install was registered in the ament index. -->
  <depend>rclcpp</depend>
  <depend>unitree_api</depend>
  <depend>unitree_go</depend>
  <depend>std_msgs</depend>
  <depend>std_srvs</depend>
  <depend>rosbag2_cpp</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
