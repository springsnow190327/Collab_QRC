<?xml version='1.0' encoding='utf-8'?>
<robot name="go2_description" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- Pure Go2 (non-W) xacro wrapper.
       Differs from go2w_description_3d_lidar.xacro:
         - FL/FR/RL/RR_foot_joint are FIXED (not continuous) — no wheel actuation.
         - Foot link visual = foot.dae (not left/right_wheel.dae).
         - Foot collision = sphere(0.022) at (-0.002, 0, 0) in calf frame — matches
           Menagerie class="foot" geom and real Unitree Go2 foot geometry.
         - ros2_control block contains 12 joints only (no FL/FR/RL/RR_foot_joint).
         - gazebo_ros2_control loads ros_control_go2_robot_a.yaml (12-joint controllers).
       The <gazebo> plugin name ``gazebo_ros2_control/GazeboSystem`` is string-replaced
       to ``mujoco_ros2_control/MujocoSystem`` by single_go2w_mujoco_cfpa2.launch.py
       at spawn time. -->

  <xacro:arg name="pointcloud_noise_enabled" default="false"/>
  <xacro:arg name="pointcloud_noise_mean" default="0.0"/>
  <xacro:arg name="pointcloud_noise_stddev" default="0.015"/>

  <xacro:include filename="$(find go2_gazebo_sim)/urdf/go2w/livox_mid360.xacro"/>
  <xacro:property name="go2_mesh_root" value="file://$(find go2_description)/dae"/>

  <xacro:livox_mid360 parent="imu" name="livox_mid360"/>

  <link name="base">
    <inertial>
      <origin xyz="0.021112 0 -0.005366" rpy="0 0 0"/>
      <mass value="6.921"/>
      <inertia ixx="0.02448" ixy="0.00012166" ixz="0.0014849"
               iyy="0.098077" iyz="-3.12E-05" izz="0.107"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${go2_mesh_root}/base.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.3762 0.0935 0.114"/>
      </geometry>
    </collision>
  </link>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="base_link_to_base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>

  <link name="Head_upper">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.09"/>
      </geometry>
    </collision>
  </link>
  <joint name="Head_upper_joint" type="fixed" dont_collapse="true">
    <origin xyz="0.285 0 0.01" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="Head_upper"/>
  </joint>
  <link name="Head_lower">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.047"/>
      </geometry>
    </collision>
  </link>
  <joint name="Head_lower_joint" type="fixed" dont_collapse="true">
    <origin xyz="0.008 0 -0.07" rpy="0 0 0"/>
    <parent link="Head_upper"/>
    <child link="Head_lower"/>
  </joint>

  <!-- ===== Front-Left leg ===== -->
  <link name="FL_hip">
    <inertial>
      <origin xyz="-0.0054 0.00194 -0.000105" rpy="0 0 0"/>
      <mass value="0.678"/>
      <inertia ixx="0.00048" ixy="-3.01E-06" ixz="1.11E-06"
               iyy="0.000884" iyz="-1.42E-06" izz="0.000596"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${go2_mesh_root}/hip.dae"/></geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0.08 0"/>
      <geometry><cylinder length="0.04" radius="0.046"/></geometry>
    </collision>
  </link>
  <joint name="FL_hip_joint" type="revolute">
    <origin xyz="0.1934 0.0465 0" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="FL_hip"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.0472" upper="1.0472" effort="23.7" velocity="30.1"/>
  </joint>
  <link name="FL_thigh">
    <inertial>
      <origin xyz="-0.00374 -0.0223 -0.0327" rpy="0 0 0"/>
      <mass value="1.152"/>
      <inertia ixx="0.00584" ixy="8.72E-05" ixz="-0.000289"
               iyy="0.0058" iyz="0.000808" izz="0.00103"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${go2_mesh_root}/thigh.dae"/></geometry>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0 0 -0.1065"/>
      <geometry><box size="0.213 0.0245 0.034"/></geometry>
    </collision>
  </link>
  <joint name="FL_thigh_joint" type="revolute">
    <origin xyz="0 0.0955 0" rpy="0 0 0"/>
    <parent link="FL_hip"/>
    <child link="FL_thigh"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5707963267948966" upper="3.4907" effort="23.7" velocity="30.1"/>
  </joint>
  <link name="FL_calf">
    <inertial>
      <origin xyz="0.00548 -0.000975 -0.115" rpy="0 0 0"/>
      <mass value="0.154"/>
      <inertia ixx="0.00108" ixy="3.4E-07" ixz="1.72E-05"
               iyy="0.0011" iyz="8.28E-06" izz="3.29E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${go2_mesh_root}/calf.dae"/></geometry>
    </visual>
    <collision>
      <origin rpy="0 -0.21 0" xyz="0.008 0 -0.06"/>
      <geometry><cylinder length="0.12" radius="0.012"/></geometry>
    </collision>
  </link>
  <joint name="FL_calf_joint" type="revolute">
    <origin xyz="0 0 -0.213" rpy="0 0 0"/>
    <parent link="FL_thigh"/>
    <child link="FL_calf"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.7227" upper="-0.83776" effort="45.43" velocity="15.70"/>
  </joint>
  <link name="FL_foot">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.04"/>
      <inertia ixx="9.6e-06" ixy="0" ixz="0" iyy="9.6e-06" iyz="0" izz="9.6e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${go2_mesh_root}/foot.dae"/></geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.002 0 0"/>
      <geometry><sphere radius="0.022"/></geometry>
    </collision>
  </link>
  <joint name="FL_foot_joint" type="fixed" dont_collapse="true">
    <origin xyz="0 0 -0.213" rpy="0 0 0"/>
    <parent link="FL_calf"/>
    <child link="FL_foot"/>
  </joint>

  <!-- ===== Front-Right leg ===== -->
  <link name="FR_hip">
