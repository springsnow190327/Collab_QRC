<?xml version="1.0"?>
<!--
  Go2 / Go2W real-robot mission launch for gbplanner3.

  Drop this into:
    $GBPLANNER_WS/src/gbplanner_ros/gbplanner/launch/gbplanner_go2.launch

  Based on the upstream ugv/gzc/ugv_gzc_urban_exploration.launch template,
  adapted for real-robot Point-LIO source (no Gazebo, no separate
  voxblox_node — voxblox config is loaded INSIDE gbplanner_node).

  It launches:
    1. gbplanner_node — gbplanner3 planner with voxblox baked in
    2. pci_general_ros_node — Planner Control Interface
       (publishes /pci_command_path PoseArray, bridged to Foxy by separate
        ros1_bridge in orin_launch_gbplanner.sh)

  Topic sources (provided by scripts/real/onboard_pointlio_noetic.sh):
    /robot/Odometry              ← Point-LIO odom @ ~10 Hz
    /robot/cloud_registered_body ← Mid-360 body-frame cloud @ ~10 Hz
    /tf, /tf_static              ← map → camera_init → body → base_link

  TF tree:
    map  ─ camera_init  (static, Mid-360 mount tilt)
           └─ body      (DYNAMIC, Point-LIO odometry output)
                └─ base_link (static, inverse mount tilt)
-->
<launch>
  <arg name="robot_name"      default="go2"/>
  <!-- 4 levels deep from config/ so that the 3×"../" in main_tree.xml BT paths
       resolve correctly to config/bt_xml/ (gbplanner3 pitfall §7). -->
  <arg name="config_folder"   default="ugv/real/go2"/>
  <arg name="odometry_topic"  default="/robot/Odometry"/>
  <arg name="pointcloud_topic" default="/robot/cloud_registered_body"/>
  <arg name="launch_prefix"   default=""/>

  <!-- Real robot: NOT sim time. -->
  <arg name="use_sim_time" default="false"/>
  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <!-- Config file paths -->
  <arg name="gbplanner_config_file"
       default="$(find gbplanner)/config/$(arg config_folder)/gbplanner_config.yaml"/>
  <arg name="pci_file"
       default="$(find gbplanner)/config/$(arg config_folder)/planner_control_interface_sim_config.yaml"/>
  <arg name="voxblox_config_file"
       default="$(find gbplanner)/config/$(arg config_folder)/voxblox_sim_config.yaml"/>
  <arg name="map_config_file"  default="$(arg voxblox_config_file)"/>
  <arg name="bt_file"
       default="$(find gbplanner)/config/$(arg config_folder)/main_tree.xml"/>

  <!-- ============================================================== -->
  <!-- GBPlanner3 main planner node (voxblox baked in)                -->
  <!-- ============================================================== -->
  <node pkg="gbplanner" type="gbplanner_node" name="gbplanner_node"
        output="screen" launch-prefix="$(arg launch_prefix)">
    <remap from="odometry"   to="$(arg odometry_topic)"/>
    <remap from="/pointcloud" to="$(arg pointcloud_topic)"/>
    <rosparam command="load" file="$(arg gbplanner_config_file)"/>
    <rosparam command="load" file="$(arg map_config_file)"/>
    <param name="behavior_tree_path" value="$(arg bt_file)"/>
  </node>

  <!-- ============================================================== -->
  <!-- Planner Control Interface (PCI) — publishes /pci_command_path  -->
  <!-- ============================================================== -->
  <node pkg="pci_general" type="pci_general_ros_node" name="pci_general_ros_node"
        output="screen">
    <!-- Output type: command/trajectory becomes our bridged topic -->
    <remap from="command/trajectory" to="/pci_command_path"/>
    <remap from="planner_server"         to="gbplanner_ros"/>
    <remap from="planner_homing_server"  to="gbplanner/homing"/>
    <remap from="odometry"               to="$(arg odometry_topic)"/>
    <rosparam command="load" file="$(arg pci_file)"/>
  </node>

  <!-- RViz NOT launched here — Orin is headless. Run separately on laptop
       (via foxglove-bridge or rsync ui.rviz + remote rviz). -->

</launch>
