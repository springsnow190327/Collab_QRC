    <framequat name="b_base_quat" objtype="site" objname="b_base_link_site"/>
    <framelinvel name="b_base_linvel" objtype="site" objname="b_base_link_site"/>
    <frameangvel name="b_base_angvel" objtype="site" objname="b_base_link_site"/>
  </sensor>
