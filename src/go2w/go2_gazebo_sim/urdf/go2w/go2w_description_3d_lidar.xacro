<?xml version='1.0' encoding='utf-8'?>
<robot name="go2w_description" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="pointcloud_noise_enabled" default="false"/>
  <xacro:arg name="pointcloud_noise_mean" default="0.0"/>
  <xacro:arg name="pointcloud_noise_stddev" default="0.015"/>
  
  <!-- Include Livox MID-360 LiDAR macro -->
  <xacro:include filename="$(find go2_gazebo_sim)/urdf/go2w/livox_mid360.xacro"/>
  <xacro:property name="go2w_mesh_root" value="file://$(find go2w_description)/dae"/>
  
  <!-- Instantiate Livox MID-360 LiDAR attached to IMU frame -->
  <xacro:livox_mid360 parent="imu" name="livox_mid360"/>
  

  <link name="base">
    <inertial>
      <origin xyz="0.021112 0 -0.005366" rpy="0 0 0" />
      <mass value="6.921" />
      <inertia ixx="0.02448" ixy="0.00012166" ixz="0.0014849" iyy="0.098077" iyz="-3.12E-05" izz="0.107" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${go2w_mesh_root}/base.dae" />
      </geometry>
      <material name="深色橡胶_001-effect"><color rgba="0.6717055 0.6924257 0.7742702 1" /></material><material name="白色logo_001-effect"><color rgba="1 1 1 1" /></material><material name="黑色贴纸_007-effect"><color rgba="0.009018 0.009018 0.009018 1" /></material><material name="黑色金属_007-effect"><color rgba="0.01341 0.01341 0.01341 1" /></material><material name="黑色塑料_003-effect"><color rgba="0.023455 0.023455 0.023455 1" /></material></visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <box size="0.3762 0.0935 0.114" />
      </geometry>
    </collision>
  </link>

  <!-- Bridge frame for controllers that expect base_link. -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
  </link>
  <joint name="base_link_to_base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base" />
    <axis xyz="0 0 0" />
  </joint>
