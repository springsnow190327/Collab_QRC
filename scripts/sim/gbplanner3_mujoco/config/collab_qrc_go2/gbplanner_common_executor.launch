<launch>
  <!-- GBPlanner3 in Collab_QRC common-executor mode.

       This is intentionally a thin ROS1 launch wrapper around the upstream
       GBPlanner3 nodes. MuJoCo, Fast-LIO, Nav2 MPPI, safety, and metrics stay
       in the ROS2 Collab_QRC stack; this launch only runs the high-level
       autonomous exploration planner and PCI trajectory publisher. -->
  <arg name="rviz_en" default="false" />
  <param name="use_sim_time" value="true"/>
  <arg name="robot_name" default="rmf" />
  <arg name="config_name" default="collab_qrc_go2" />
  <arg name="ele_map_enable" default="true" />

  <arg name="gbplanner_config_file" default="$(find robot_bringup)/config/ros1/gbplanner/$(arg config_name)/gbplanner_config.yaml" />
  <arg name="voxblox_config_file" default="$(find robot_bringup)/config/ros1/gbplanner/$(arg config_name)/voxblox_config.yaml" />
  <arg name="pci_file" default="$(find robot_bringup)/config/ros1/gbplanner/$(arg config_name)/planner_control_interface_config.yaml" />
  <arg name="manhole_config_file" default="$(find robot_bringup)/config/ros1/gbplanner/$(arg config_name)/manhole_detector.yaml"/>
  <arg name="elevation_map_config_file" default="$(find robot_bringup)/config/ros1/gbplanner/$(arg config_name)/elevation_mapping_config.yaml" if="$(arg ele_map_enable)"/>
  <arg name="elevation_map_config_file" default="" unless="$(arg ele_map_enable)"/>
  <arg name="map_config_file" default="$(arg voxblox_config_file)" />
  <arg name="odometry_topic" default="/$(arg robot_name)/odom" />

  <node pkg="gbplanner" type="gbplanner_node" name="gbplanner_node" output="screen">
    <remap from="odometry" to="$(arg odometry_topic)" />
    <remap from="/pointcloud" to="/$(arg robot_name)/lidar/points_downsampled" />
    <remap from="freespace_pointcloud" to="/$(arg robot_name)/lidar/freespace_points" />
    <remap from="/gbplanner_path" to="/$(arg robot_name)/gbplanner_path" />
    <rosparam command="load" file="$(arg gbplanner_config_file)" />
    <rosparam command="load" file="$(arg map_config_file)" />
    <remap from="transform" to="/$(arg robot_name)/base_link/lidar" />
    <remap from="manhole_detections" to="stable_detections" />
    <remap from="local_navigation_goal" to="/move_base_simple/goal"/>
    <remap from="elevation_map" to="/elevation_mapping_lidar/elevation_map_raw" />
    <param name="behavior_tree_path" value="$(find robot_bringup)/config/ros1/bt_xml/main_tree.xml"/>
  </node>

  <node pkg="pci_general" type="pci_general_ros_node" name="pci_general_ros_node" output="screen">
    <remap from="planner_server" to="gbplanner_ros" />
    <remap from="planner_homing_server" to="gbplanner_ros_homing" />
    <remap from="odometry" to="$(arg odometry_topic)"/>
    <remap from="command/trajectory" to="/$(arg robot_name)/command/trajectory"/>
    <remap from="/gbplanner_path" to="/$(arg robot_name)/gbplanner_path"/>
    <rosparam command="load" file="$(arg pci_file)" />
  </node>

  <node pkg="elevation_mapping" type="elevation_mapping" name="elevation_mapping_lidar" output="screen" if="$(arg ele_map_enable)">
    <rosparam command="load" file="$(arg elevation_map_config_file)" />
  </node>
  <node pkg="robot_bringup" type="pcl_proc.py" name="pcl_proc" output="screen" if="$(arg ele_map_enable)"/>

  <node pkg="rviz" type="rviz" name="gbplanner_ui" output="screen"
        args="-d $(find robot_bringup)/rviz/ros1/$(arg robot_name).rviz"
        if="$(arg rviz_en)"/>
</launch>
