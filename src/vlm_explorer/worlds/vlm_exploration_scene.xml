          size="0.05 0.05 0.05" euler="0 0 0.6" material="red_mat"
          contype="1" conaffinity="1"/>
    <!-- Room D: far east -->
    <geom name="red_block_7" type="box" pos="10.5 -3.2 0.05"
          size="0.05 0.05 0.05" euler="0 0 1.5" material="red_mat"
