<mujoco model="go2w">
  <compiler angle="radian" meshdir="meshes"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <default>
    <joint damping="0.5" armature="0.01"/>
    <geom friction="1.0 0.005 0.001" condim="3" conaffinity="1" contype="1"/>
    <motor ctrllimited="true"/>
  </default>

  <asset>
    <mesh name="left_wheel" file="left_wheel.stl"/>
    <mesh name="right_wheel" file="right_wheel.stl"/>
    <texture type="2d" name="groundplane" builtin="checker" rgb1="0.4 0.4 0.4" rgb2="0.5 0.5 0.5"
             width="300" height="300" mark="edge" markrgb="0.3 0.3 0.3"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" texuniform="true" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="20 20 0.1" material="groundplane"/>

    <!-- Robot base with freejoint for floating base dynamics -->
    <body name="base_link" pos="4.0 0 0.5">
      <freejoint name="root"/>
      <inertial pos="0.021112 0 -0.005366" mass="6.921"
                fullinertia="0.02448 0.098077 0.107 0.00012166 0.0014849 -3.12e-05"/>
      <!-- Base collision box -->
      <geom name="base_collision" size="0.1881 0.04675 0.057" type="box" rgba="0.671705 0.692426 0.77427 1"/>
      <!-- Head upper -->
      <geom size="0.06 0.045" pos="0.285 0 0.01" type="cylinder" contype="0" conaffinity="0"/>
      <!-- Head lower -->
      <geom size="0.06" pos="0.293 0 -0.06" contype="0" conaffinity="0"/>
      <!-- LiDAR mount -->
      <geom size="0.043 0.043 0.021" pos="0.16143 0 0.12262"
            quat="-0.0800485 0.0800501 0.702563 0.70256" type="box" contype="0" conaffinity="0"/>

      <!-- IMU site (on base body) -->
      <site name="imu_site" pos="0.16143 0 0.09787" size="0.01"/>

      <!-- Camera site (front-facing) -->
      <camera name="front_camera" pos="0.3 0 0.0" euler="0 0 0" fovy="120"
              resolution="1280 720" mode="fixed"/>

      <!-- ====== Front-Left leg ====== -->
      <body name="FL_hip" pos="0.1934 0.0465 0">
        <inertial pos="-0.0054 0.00194 -0.000105" quat="0.497014 0.499245 0.505462 0.498237"
                  mass="0.678" diaginertia="0.00088403 0.000596003 0.000479967"/>
        <joint name="FL_hip_joint" axis="1 0 0" range="-1.0472 1.0472"/>
        <geom size="0.046 0.02" pos="0 0.08 0" quat="0.707107 0.707107 0 0" type="cylinder"
              rgba="0.671705 0.692426 0.77427 1"/>
        <body name="FL_thigh" pos="0 0.0955 0">
          <inertial pos="-0.00374 -0.0223 -0.0327" quat="0.829533 0.0847635 -0.0200632 0.551623"
                    mass="1.152" diaginertia="0.00594973 0.00584149 0.000878787"/>
          <joint name="FL_thigh_joint" axis="0 1 0" range="-1.5708 3.4907"/>
          <geom size="0.055 0.01225 0.017" pos="0 0 -0.1065" quat="0.707107 0 0.707107 0"
                type="box" rgba="0.671705 0.692426 0.77427 1"/>
          <body name="FL_calf" pos="0 0 -0.213">
            <inertial pos="-0.00583047 -0.000177199 -0.202827" quat="0.706542 0.0341434 0.029565 0.706229"
                      mass="0.847352" diaginertia="0.00439089 0.00374067 0.0010673"/>
            <joint name="FL_calf_joint" axis="0 1 0" range="-2.7227 -0.83776"/>
            <geom size="0.012 0.06" pos="0.008 0 -0.06" quat="0.994493 0 -0.104807 0" type="cylinder" rgba="1 1 1 1"/>
            <geom size="0.011 0.0325" pos="0.02 0 -0.148" quat="0.999688 0 0.0249974 0" type="cylinder"/>
            <geom size="0.0155 0.015" pos="0.00801333 0 -0.18745" quat="0.965093 0 0.261909 0" type="cylinder"/>
            <geom size="0.05 0.025" pos="0 0.01 -0.2264" quat="0.707107 0.707107 0 0" type="cylinder"/>
            <body name="FL_foot" pos="0 0 -0.2264">
              <inertial pos="0 0.06 0" quat="0.707107 0 0 0.707107" mass="0.52" diaginertia="0.0012 0.0007 0.0007"/>
              <joint name="FL_foot_joint" axis="0 1 0"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="left_wheel"/>
              <site name="FL_foot_site" pos="0 0.06 0" size="0.01"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ====== Front-Right leg ====== -->
      <body name="FR_hip" pos="0.1934 -0.0465 0">
        <inertial pos="-0.0054 -0.00194 -0.000105" quat="0.498237 0.505462 0.499245 0.497014"
                  mass="0.678" diaginertia="0.00088403 0.000596003 0.000479967"/>
        <joint name="FR_hip_joint" axis="1 0 0" range="-1.0472 1.0472"/>
        <geom size="0.046 0.02" pos="0 -0.08 0" quat="0.707107 0.707107 0 0" type="cylinder"
              rgba="0.671705 0.692426 0.77427 1"/>
        <body name="FR_thigh" pos="0 -0.0955 0">
          <inertial pos="-0.00374 0.0223 -0.0327" quat="0.551623 -0.0200632 0.0847635 0.829533"
                    mass="1.152" diaginertia="0.00594973 0.00584149 0.000878787"/>
          <joint name="FR_thigh_joint" axis="0 1 0" range="-1.5708 3.4907"/>
          <geom size="0.055 0.01225 0.017" pos="0 0 -0.1065" quat="0.707107 0 0.707107 0"
                type="box" rgba="0.671705 0.692426 0.77427 1"/>
          <body name="FR_calf" pos="0 0 -0.213">
            <inertial pos="0.00941703 0.000177199 -0.202827" quat="0.706926 -0.0108701 -0.00627168 0.707176"
                      mass="0.847352" diaginertia="0.00434456 0.00372059 0.00104105"/>
            <joint name="FR_calf_joint" axis="0 1 0" range="-2.7227 -0.83776"/>
            <geom size="0.013 0.06" pos="0.01 0 -0.06" quat="0.995004 0 -0.0998334 0" type="cylinder" rgba="1 1 1 1"/>
            <geom size="0.011 0.0325" pos="0.02 0 -0.148" quat="0.999688 0 0.0249974 0" type="cylinder"/>
            <geom size="0.0155 0.015" pos="0.00801333 0 -0.18745" quat="0.965093 0 0.261909 0" type="cylinder"/>
            <geom size="0.05 0.025" pos="0 -0.01 -0.2264" quat="0.707107 0.707107 0 0" type="cylinder"/>
            <body name="FR_foot" pos="0 0 -0.2264">
              <inertial pos="0 -0.06 0" quat="0.707107 0 0 0.707107" mass="0.52" diaginertia="0.0012 0.0007 0.0007"/>
              <joint name="FR_foot_joint" axis="0 1 0"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="right_wheel"/>
              <site name="FR_foot_site" pos="0 -0.06 0" size="0.01"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ====== Rear-Left leg ====== -->
      <body name="RL_hip" pos="-0.1934 0.0465 0">
        <inertial pos="0.0054 0.00194 -0.000105" quat="0.505462 0.498237 0.497014 0.499245"
                  mass="0.678" diaginertia="0.00088403 0.000596003 0.000479967"/>
        <joint name="RL_hip_joint" axis="1 0 0" range="-1.0472 1.0472"/>
        <geom size="0.046 0.02" pos="0 0.08 0" quat="0.707107 0.707107 0 0" type="cylinder"
              rgba="0.671705 0.692426 0.77427 1"/>
        <body name="RL_thigh" pos="0 0.0955 0">
          <inertial pos="-0.00374 -0.0223 -0.0327" quat="0.829533 0.0847635 -0.0200632 0.551623"
                    mass="1.152" diaginertia="0.00594973 0.00584149 0.000878787"/>
          <joint name="RL_thigh_joint" axis="0 1 0" range="-0.5236 4.5379"/>
          <geom size="0.055 0.01225 0.017" pos="0 0 -0.1065" quat="0.707107 0 0.707107 0"
                type="box" rgba="0.671705 0.692426 0.77427 1"/>
          <body name="RL_calf" pos="0 0 -0.213">
            <inertial pos="-0.00583047 -0.000177199 -0.202827" quat="0.706542 0.0341434 0.029565 0.706229"
                      mass="0.847352" diaginertia="0.00439089 0.00374067 0.0010673"/>
            <joint name="RL_calf_joint" axis="0 1 0" range="-2.7227 -0.83776"/>
            <geom size="0.013 0.06" pos="0.01 0 -0.06" quat="0.995004 0 -0.0998334 0" type="cylinder" rgba="1 1 1 1"/>
            <geom size="0.011 0.0325" pos="0.02 0 -0.148" quat="0.999688 0 0.0249974 0" type="cylinder"/>
            <geom size="0.0155 0.015" pos="0.00801333 0 -0.18745" quat="0.965093 0 0.261909 0" type="cylinder"/>
            <geom size="0.05 0.025" pos="0 0.01 -0.2264" quat="0.707107 0.707107 0 0" type="cylinder"/>
            <body name="RL_foot" pos="0 0 -0.2264">
              <inertial pos="0 0.06 0" quat="0.707107 0 0 0.707107" mass="0.52" diaginertia="0.0012 0.0007 0.0007"/>
              <joint name="RL_foot_joint" axis="0 1 0"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="left_wheel"/>
              <site name="RL_foot_site" pos="0 0.06 0" size="0.01"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ====== Rear-Right leg ====== -->
      <body name="RR_hip" pos="-0.1934 -0.0465 0">
        <inertial pos="0.0054 -0.00194 -0.000105" quat="0.499245 0.497014 0.498237 0.505462"
                  mass="0.678" diaginertia="0.00088403 0.000596003 0.000479967"/>
        <joint name="RR_hip_joint" axis="1 0 0" range="-1.0472 1.0472"/>
        <geom size="0.046 0.02" pos="0 -0.08 0" quat="0.707107 0.707107 0 0" type="cylinder"
              rgba="0.671705 0.692426 0.77427 1"/>
        <body name="RR_thigh" pos="0 -0.0955 0">
          <inertial pos="-0.00374 0.0223 -0.0327" quat="0.551623 -0.0200632 0.0847635 0.829533"
                    mass="1.152" diaginertia="0.00594973 0.00584149 0.000878787"/>
          <joint name="RR_thigh_joint" axis="0 1 0" range="-0.5236 4.5379"/>
          <geom size="0.055 0.01225 0.017" pos="0 0 -0.1065" quat="0.707107 0 0.707107 0"
                type="box" rgba="0.671705 0.692426 0.77427 1"/>
          <body name="RR_calf" pos="0 0 -0.213">
            <inertial pos="0.00941703 0.000177199 -0.202827" quat="0.706926 -0.0108701 -0.00627168 0.707176"
                      mass="0.847352" diaginertia="0.00434456 0.00372059 0.00104105"/>
            <joint name="RR_calf_joint" axis="0 1 0" range="-2.7227 -0.83776"/>
            <geom size="0.013 0.06" pos="0.01 0 -0.06" quat="0.995004 0 -0.0998334 0" type="cylinder" rgba="1 1 1 1"/>
            <geom size="0.011 0.0325" pos="0.02 0 -0.148" quat="0.999688 0 0.0249974 0" type="cylinder"/>
            <geom size="0.0155 0.015" pos="0.00801333 0 -0.18745" quat="0.965093 0 0.261909 0" type="cylinder"/>
            <geom size="0.05 0.025" pos="0 -0.01 -0.2264" quat="0.707107 0.707107 0 0" type="cylinder"/>
            <body name="RR_foot" pos="0 0 -0.2264">
              <inertial pos="0 -0.06 0" quat="0.707107 0 0 0.707107" mass="0.52" diaginertia="0.0012 0.0007 0.0007"/>
              <joint name="RR_foot_joint" axis="0 1 0"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="right_wheel"/>
              <site name="RR_foot_site" pos="0 -0.06 0" size="0.01"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators: effort for leg joints, velocity for wheel joints -->
  <actuator>
    <!-- Hip joints (effort-controlled) -->
    <motor name="FL_hip_motor" joint="FL_hip_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="FR_hip_motor" joint="FR_hip_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="RL_hip_motor" joint="RL_hip_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="RR_hip_motor" joint="RR_hip_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <!-- Thigh joints (effort-controlled) -->
    <motor name="FL_thigh_motor" joint="FL_thigh_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="FR_thigh_motor" joint="FR_thigh_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="RL_thigh_motor" joint="RL_thigh_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <motor name="RR_thigh_motor" joint="RR_thigh_joint" ctrlrange="-23.7 23.7" gear="1"/>
    <!-- Calf joints (effort-controlled, higher torque) -->
    <motor name="FL_calf_motor" joint="FL_calf_joint" ctrlrange="-35.55 35.55" gear="1"/>
    <motor name="FR_calf_motor" joint="FR_calf_joint" ctrlrange="-35.55 35.55" gear="1"/>
    <motor name="RL_calf_motor" joint="RL_calf_joint" ctrlrange="-35.55 35.55" gear="1"/>
    <motor name="RR_calf_motor" joint="RR_calf_joint" ctrlrange="-35.55 35.55" gear="1"/>
    <!-- Wheel joints (velocity-controlled) -->
    <velocity name="FL_wheel_motor" joint="FL_foot_joint" ctrlrange="-23.7 23.7" kv="5.0"/>
    <velocity name="FR_wheel_motor" joint="FR_foot_joint" ctrlrange="-23.7 23.7" kv="5.0"/>
    <velocity name="RL_wheel_motor" joint="RL_foot_joint" ctrlrange="-23.7 23.7" kv="5.0"/>
    <velocity name="RR_wheel_motor" joint="RR_foot_joint" ctrlrange="-23.7 23.7" kv="5.0"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- IMU -->
    <accelerometer name="imu_accel" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <!-- Foot contact (touch sensors) -->
    <touch name="FL_foot_contact" site="FL_foot_site"/>
    <touch name="FR_foot_contact" site="FR_foot_site"/>
    <touch name="RL_foot_contact" site="RL_foot_site"/>
    <touch name="RR_foot_contact" site="RR_foot_site"/>
    <!-- Base body state (ground truth) -->
    <framepos name="base_pos" objtype="body" objname="base_link"/>
    <framequat name="base_quat" objtype="body" objname="base_link"/>
    <framelinvel name="base_linvel" objtype="body" objname="base_link"/>
    <frameangvel name="base_angvel" objtype="body" objname="base_link"/>
  </sensor>
</mujoco>
