# syntax=docker/dockerfile:1.4

# Jazzy targets Ubuntu 24.04. Use an NVIDIA CUDA base so CuPy + torch can use the GPU.
FROM nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04

ARG ROS_DISTRO=jazzy
ARG USERNAME=ubuntu
ARG USER_UID=1000
ARG USER_GID=$USER_UID

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    TZ=UTC \
    ROS_DISTRO=${ROS_DISTRO}

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt update && apt install -y --no-install-recommends \
      locales tzdata \
      curl gnupg2 lsb-release \
      sudo git \
      build-essential cmake \
      python3-pip python3-venv \
    && locale-gen en_US.UTF-8 \
    && update-locale LC_ALL=${LC_ALL} LANG=${LANG} \
    && rm -rf /var/lib/apt/lists/*

# ROS2 apt repo
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) main" \
      > /etc/apt/sources.list.d/ros2.list \
    && apt update && apt install -y --no-install-recommends \
      ros-${ROS_DISTRO}-ros-base \
      ros-${ROS_DISTRO}-rviz2 \
      ros-${ROS_DISTRO}-cv-bridge \
      ros-${ROS_DISTRO}-message-filters \
      ros-${ROS_DISTRO}-sensor-msgs-py \
      ros-${ROS_DISTRO}-std-srvs \
      ros-${ROS_DISTRO}-tf-transformations \
      ros-${ROS_DISTRO}-grid-map-msgs \
      ros-${ROS_DISTRO}-grid-map-rviz-plugin \
      ros-${ROS_DISTRO}-nav-msgs \
      ros-${ROS_DISTRO}-pcl-ros \
      ros-${ROS_DISTRO}-rosbag2-py \
      ros-${ROS_DISTRO}-rosbag2-storage-mcap \
      ros-${ROS_DISTRO}-ament-cmake \
      ros-${ROS_DISTRO}-ament-cmake-python \
      ros-${ROS_DISTRO}-ament-cmake-ros \
      ros-${ROS_DISTRO}-ament-cmake-pytest \
      ros-${ROS_DISTRO}-ament-lint-auto \
      ros-${ROS_DISTRO}-ament-lint-common \
      ros-${ROS_DISTRO}-launch-testing \
      ros-${ROS_DISTRO}-launch-testing-ament-cmake \
      ros-${ROS_DISTRO}-launch-testing-ros \
      ros-${ROS_DISTRO}-rosidl-default-generators \
      python3-colcon-common-extensions \
      python3-rosdep \
      python3-vcstool \
      python3-numpy \
      python3-opencv \
      python3-pytest \
      python3-scipy \
      python3-sklearn \
      python3-shapely \
      python3-transforms3d \
      python3-ruamel.yaml \
      python3-yaml \
    && rm -rf /var/lib/apt/lists/*

# Torch: traversability filter backend (CUDA). Use cu121 wheels (works on modern drivers).
RUN python3 -m pip install --no-cache-dir --break-system-packages -U --extra-index-url https://download.pytorch.org/whl/cu121 \
    torch torchvision torchaudio

RUN python3 -m pip install --no-cache-dir --break-system-packages \
    cupy-cuda12x \
    simple-parsing

# Non-root user (so mounted workspaces behave).
# NOTE: NVIDIA CUDA base images already ship with `ubuntu:1000:1000`.
RUN if ! getent group ${USER_GID} >/dev/null; then groupadd --gid ${USER_GID} ${USERNAME}; fi \
    && if ! id -u ${USERNAME} >/dev/null 2>&1; then useradd -m -s /bin/bash --uid ${USER_UID} --gid ${USER_GID} ${USERNAME}; fi \
    && echo "${USERNAME} ALL=(root) NOPASSWD:ALL" > /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME}

RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> /home/${USERNAME}/.bashrc

# rosdep init must run once (as root) inside the image.
RUN rosdep init || true

WORKDIR /home/${USERNAME}/workspace
USER ${USERNAME}

CMD ["bash"]
