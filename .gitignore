# =============================================
# SLAM output artifacts
# =============================================
*.ply
# Exception: vendored CMU local_planner motion-primitive files. localPlanner
# crashes on startup (SIGSEGV) without these; can be regenerated via
# path_generator.m but checking them in saves a MATLAB dependency.
!src/vendor/far_planner/base_autonomy/local_planner/paths/*.ply
*.pbstream
*.pgm
carto_*.yaml
carto_*.png
carto_*.csv

