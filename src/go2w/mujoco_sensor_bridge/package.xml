<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mujoco_sensor_bridge</name>
  <version>0.1.0</version>
  <description>Sensor bridge nodes for MuJoCo simulation of Go2W.
    Provides LiDAR raycasting (PointCloud2), foot contact sensing (ContactsStamped),
    and ground-truth odometry conversion from mujoco_ros2_control outputs.</description>
  <maintainer email="hz@todo.todo">Hanshang Zhu</maintainer>
  <license>BSD-3-Clause</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <exec_depend>rclpy</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>nav_msgs</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>std_msgs</exec_depend>
  <exec_depend>tf2_ros_py</exec_depend>
  <exec_depend>tf2_geometry_msgs</exec_depend>
  <exec_depend>champ_msgs</exec_depend>
  <exec_depend>python3-numpy</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
