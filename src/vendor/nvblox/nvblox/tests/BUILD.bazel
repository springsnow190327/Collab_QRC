# CUDA tests
[
    genrule(
        name = "convert_{}_to_cpp".format(test_name),
        srcs = ["{}.cu".format(test_name)],
        outs = ["{}.cu.cpp".format(test_name)],
        cmd = "cp $(SRCS) $(OUTS)",
    )
    for test_name in NVBLOX_CUDA_TESTS
]

[
    cuda_test(
        name = test_name,
        size = "large",
        srcs = ["{}.cu.cpp".format(test_name)],
        copts = [
            "--expt-relaxed-constexpr",
            "--extended-lambda",
            "--disable-warnings",
            "--diag-suppress=20012",
        ],
        data = [
            ":test_data",
            "//executables:fuser",
        ],
        defines = [
            "STBI_NO_FAILURE_STRINGS",
            "USE_BAZEL_RUNFILES",
