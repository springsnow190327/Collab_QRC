    <accelerometer name="b_imu_accel" site="b_imu"/>
    <gyro name="b_imu_gyro" site="b_imu"/>

    <!-- Foot contact (touch sensors) -->
    <touch name="b_FL_foot_contact" site="b_FL_foot_site"/>
