  </joint>

  <!-- ===== IMU + radar ===== -->
  <link name="imu">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="-0.02557 0 0.04232" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="imu"/>
  </joint>
  <link name="radar">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>
  <joint name="radar_joint" type="fixed">
    <origin xyz="0.28945 0 -0.046825" rpy="0 2.8782 0"/>
    <parent link="base"/>
    <child link="radar"/>
  </joint>

  <!-- ===== Front camera for VLM pipeline ===== -->
  <link name="front_camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.03 0.02"/></geometry>
      <material name="camera_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>
  <joint name="front_camera_joint" type="fixed">
    <origin xyz="0.015 0.0 -0.02" rpy="0 0.0873 0"/>
    <parent link="Head_upper"/>
    <child link="front_camera_link"/>
  </joint>

  <!-- ===== Gazebo IMU stream (unused in MuJoCo but kept for parity) ===== -->
  <gazebo reference="imu">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200.0</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros><remapping>~/out:=/imu/data</remapping></ros>
        <frame_name>imu</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="livox_mid360">
    <sensor name="lidar_3d" type="gpu_ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.7330</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.05</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
        <xacro:if value="$(arg pointcloud_noise_enabled)">
          <noise>
            <type>gaussian</type>
            <mean>$(arg pointcloud_noise_mean)</mean>
            <stddev>$(arg pointcloud_noise_stddev)</stddev>
          </noise>
        </xacro:if>
      </ray>
      <plugin name="gazebo_ros_3d_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=/registered_scan</remapping></ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frameName>livox_mid360</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="front_camera_link">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>10.0</update_rate>
      <camera>
        <horizontal_fov>2.0944</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.05</near><far>30.0</far></clip>
      </camera>
      <plugin name="gazebo_ros_front_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=front_camera/image_raw</remapping>
          <remapping>~/camera_info:=front_camera/camera_info</remapping>
        </ros>
        <frame_name>front_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base">
    <sensor name="base_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <contact>
        <collision>base_link_fixed_joint_lump__base_collision</collision>
      </contact>
      <plugin name="gazebo_ros_bumper" filename="libgazebo_ros_bumper.so">
        <ros><remapping>bumper_states:=contact_states</remapping></ros>
        <frame_name>base_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="p3d_base_controller" filename="libgazebo_ros_p3d.so">
      <ros><remapping>odom:=odom/ground_truth</remapping></ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <update_rate>50.0</update_rate>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.01</gaussian_noise>
    </plugin>
  </gazebo>

  <!-- ros2_control plugin loader. The plugin name and YAML path get string-
       replaced by single_go2w_mujoco_cfpa2.launch.py when running under MuJoCo:
         gazebo_ros2_control/GazeboSystem → mujoco_ros2_control/MujocoSystem
       The YAML is swapped to ros_control_go2_robot_a.yaml via
       build_namespaced_robot_description when has_wheels=false. -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find go2_gazebo_sim)/config/ros_control/ros_control_go2_robot_a.yaml</parameters>
    </plugin>
  </gazebo>

  <ros2_control name="go2_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="FL_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
