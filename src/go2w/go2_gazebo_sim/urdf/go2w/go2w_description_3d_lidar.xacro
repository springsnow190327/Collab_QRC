  </inertial>
  <collision>
    <origin rpy="1.5707963267948966 0 0" xyz="0 0 0" />
    <geometry>
      <cylinder length="0.05" radius="0.05" />
    </geometry>
  </collision>
</link>

<joint name="RR_foot_motor_joint" type="fixed">
  <origin xyz="0.00 -0.01 -0.2264" rpy="0 0.0 0" />
  <parent link="RR_calf" />
  <child link="RR_foot_motor" />
  <axis xyz="0 0 0" />
</joint>

  <link name="RR_foot">
    <inertial>
      <origin xyz="0 -0.06 0" rpy="0 0 0" />
      <mass value="0.520" />
      <inertia ixx="0.0007" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0007" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${go2w_mesh_root}/right_wheel.dae" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 -0.0 0" />
      <geometry>
        <mesh filename="${go2w_mesh_root}/right_wheel.dae" />
        
      </geometry>
    </collision>
  </link>
  <joint name="RR_foot_joint" type="continuous">
    <origin xyz="-0.0 0 -0.2264" rpy="0 0 0" />
    <parent link="RR_calf" />
    <child link="RR_foot" />
    <axis xyz="0 1 0" />
      <limit effort="23.7" velocity="30.1" />
  </joint>
  <link name="imu">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="-0.02557 0 0.04232" rpy="0 0 0" />
    <parent link="base" />
    <child link="imu" />
    <axis xyz="0 0 0" />
  </joint>
  <link name="radar">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
  </link>
  <joint name="radar_joint" type="fixed">
    <origin xyz="0.28945 0 -0.046825" rpy="0 2.8782 0" />
    <parent link="base" />
    <child link="radar" />
    <axis xyz="0 0 0" />
  </joint>

  <!-- Gazebo IMU stream for SLAM pipelines expecting /imu/data.
       Noise values are BMI088-class (Unitree Go2 actual IMU):
       gyro noise density ~0.0017 rad/s, accel noise density ~0.017 m/s². -->
  <gazebo reference="imu">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200.0</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0017</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu/data</remapping>
        </ros>
        <frame_name>imu</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Gazebo LiDAR stream approximating Unitree L1 4D LiDAR.
       Real L1: 360° H x 90° V (upper hemisphere), 0.05-20m range, ~21600 pts/s.
       Gazebo Classic gpu_ray crashes (SIGSEGV) when vertical max_angle exceeds
       ~0.78 rad (~45°), so we cap at +42° here.  With the 13° forward tilt from
       the livox_mid360.xacro joint, effective world-frame vertical coverage is
       approximately -28° to +29° — enough to see walls and low ceilings.
       Range min lowered to 0.05m (L1 near blind zone). -->
  <gazebo reference="livox_mid360">
    <sensor name="lidar_3d" type="gpu_ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.7330</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.05</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
        <xacro:if value="$(arg pointcloud_noise_enabled)">
          <noise>
            <type>gaussian</type>
            <mean>$(arg pointcloud_noise_mean)</mean>
            <stddev>$(arg pointcloud_noise_stddev)</stddev>
          </noise>
        </xacro:if>
      </ray>
      <plugin name="gazebo_ros_3d_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/registered_scan</remapping>
        </ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frameName>livox_mid360</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Front camera for VLM exploration pipeline.
       Mounted on Head_upper (~0.30m forward, 0.01m up from base),
       pitched down ~5 deg for ground-ahead coverage.
       1280x720, 120 deg HFOV, 10 Hz. -->
  <link name="front_camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.02"/>
      </geometry>
      <material name="camera_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>
  <joint name="front_camera_joint" type="fixed">
    <!-- Relative to Head_upper which is already at [0.285, 0, 0.01] from base.
         Offset slightly forward + down with 5 deg pitch. -->
    <origin xyz="0.015 0.0 -0.02" rpy="0 0.0873 0"/>
    <parent link="Head_upper"/>
    <child link="front_camera_link"/>
  </joint>

  <gazebo reference="front_camera_link">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>10.0</update_rate>
      <camera>
        <horizontal_fov>2.0944</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
      <plugin name="gazebo_ros_front_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=front_camera/image_raw</remapping>
          <remapping>~/camera_info:=front_camera/camera_info</remapping>
        </ros>
        <frame_name>front_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Contact sensor on robot body for collision detection. -->
  <gazebo reference="base">
    <sensor name="base_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <contact>
        <collision>base_link_fixed_joint_lump__base_collision</collision>
      </contact>
      <plugin name="gazebo_ros_bumper" filename="libgazebo_ros_bumper.so">
        <ros>
          <remapping>bumper_states:=contact_states</remapping>
        </ros>
        <frame_name>base_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Ground-truth odometry for navigation bootstrap. -->
  <gazebo>
    <plugin name="p3d_base_controller" filename="libgazebo_ros_p3d.so">
      <ros>
        <remapping>odom:=odom/ground_truth</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <update_rate>50.0</update_rate>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.01</gaussian_noise>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find go2_gazebo_sim)/config/ros_control/ros_control_go2w_robot_a.yaml</parameters>
    </plugin>
  </gazebo>

  <ros2_control name="go2w_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="FL_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_foot_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_foot_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_foot_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_hip_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_thigh_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_calf_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_foot_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
