Panels:
  - Class: rviz_common/Displays
    Help Height: 60
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /OctoMapVoxels1
        - /RegisteredCloud1
      Splitter Ratio: 0.55
    Tree Height: 700
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.59
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    # ── Reference grid + TF tree ──
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 40
      Reference Frame: map
      Value: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: false
        base_link: { Value: true }
        map: { Value: true }
        body: { Value: false }
        body_lidar: { Value: false }
        camera_init: { Value: false }
      Marker Scale: 0.8
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: true
      Value: true
    # ── Occupancy grid underlay (dimmed, for spatial context) ──
    - Alpha: 0.40
      Class: rviz_default_plugins/Map
      Color Scheme: map
      Draw Behind: true
      Enabled: true
      Name: OccupancyUnderlay
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/map
      Use Timestamp: false
      Value: true
    # ── 3D voxel grid (octomap colorised centres) ──
    # octomap_server publishes voxel centers as PointCloud2 with RGB intensity
    # mapped from z-height. Works on the default rviz_default_plugins package,
    # no octomap_rviz_plugins dep needed.
    - Alpha: 1.0
      Autocompute Intensity Bounds: false
      Autocompute Value Bounds: { Max Value: 2.0, Min Value: 0.0, Value: true }
      Axis: Z
      Channel Name: z
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 255; 255
      Color Transformer: AxisColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 2.0
      Min Color: 0; 0; 0
      Min Intensity: 0.0
      Name: OctoMapVoxels
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.05
      Style: Boxes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/octomap_point_cloud_centers
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    # ── Live registered scan (current sweep in world frame) ──
    # fastlio_mid360 publishes /cloud_registered. carto_l1 doesn't register
    # clouds in world frame; /utlidar/transformed_cloud is in body, so in
    # that case this display stays empty unless slam=fastlio is running.
    - Alpha: 0.8
      Class: rviz_default_plugins/PointCloud2
      Color: 0; 255; 255
      Color Transformer: FlatColor
      Decay Time: 0.2
      Enabled: true
      Name: RegisteredCloud
      Position Transformer: XYZ
      Selectable: false
      Size (Pixels): 2
      Size (m): 0.03
      Style: Points
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /cloud_registered
      Use Fixed Frame: true
      Value: true
    # ── LaserScan (the 2D slice that planners use) ──
    - Alpha: 1
      Class: rviz_default_plugins/LaserScan
      Color: 255; 255; 0
      Color Transformer: FlatColor
      Decay Time: 0.5
      Enabled: true
      Name: PlannerLaserScan
      Size (m): 0.05
      Style: Points
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/scan_3d
      Use Fixed Frame: true
      Value: true
    # ── Planned path ──
    - Alpha: 1
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color: 255; 50; 50
      Enabled: true
      Head Diameter: 0.15
      Head Length: 0.15
      Length: 0.3
      Line Style: Billboards
      Line Width: 0.05
      Name: PlannedPath
      Pose Style: None
      Radius: 0.03
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/planned_path
      Value: true
    # ── Robot trajectory breadcrumbs ──
    - Alpha: 1
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color: 30; 220; 50
      Enabled: true
      Name: RobotTrajectory
      Line Style: Billboards
      Line Width: 0.03
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/robot_trajectory
      Value: true
    # ── Red robot-pose triangle (same as 2D view) ──
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: RobotPoseTriangle
      Namespaces:
        robot_pose: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/robot_pose_marker
      Value: true
    # ── Frontier cylinders ──
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: FrontierCylinders
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/frontier_cylinders
      Value: true
    # ── Goal marker (star) ──
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: FinalGoalMarker
      Namespaces:
        "": true
        final_goal: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/final_goal_marker
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetInitialPose
      Topic: { Value: /initialpose }
    - Class: rviz_default_plugins/SetGoal
      Topic: { Value: /goal_pose }
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic: { Value: /clicked_point }
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 10.0
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point: { X: 0, Y: 0, Z: 0 }
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Pitch: 0.55
      Target Frame: base_link
      Value: Orbit (rviz_default_plugins)
      Yaw: 3.14
    Saved: ~
Window Geometry:
  Displays: { collapsed: false }
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Selection: { collapsed: false }
  Tool Properties: { collapsed: false }
  Views: { collapsed: false }
  Width: 1600
  X: 80
  Y: 48
