# =============================================
# C++ build artifacts
# =============================================
*.o
*.a
*.so
*.so.*
*.dylib
*.d
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake

# =============================================
# Local debug artifacts
# =============================================
*.log
*.gv
*.pdf
*.tmp
core
core.*
# `core` above is meant for Linux core dumps but also silently swallowed any
# `core/` directory in the tree — including the ROS-independent algorithm
# namespace `include/.../core/` that the 2026-05-19 hexagonal CFPA2 port
# introduced. Whitelist `core/` subdirs that live under an `include/` path
# (common C++ namespace convention) so they commit cleanly.
!**/include/**/core/
!**/include/**/core/**
# MuJoCo runtime log (regenerated each run)
MUJOCO_LOG.TXT
*.pdf

# =============================================
# SLAM output artifacts
# =============================================
*.ply
# Exception: vendored CMU local_planner motion-primitive files. localPlanner
# crashes on startup (SIGSEGV) without these; can be regenerated via
# path_generator.m but checking them in saves a MATLAB dependency.
!src/vendor/far_planner/base_autonomy/local_planner/paths/*.ply
*.pbstream
*.pgm
carto_*.yaml
carto_*.png
carto_*.csv

# =============================================
# Traversability CNN training artifacts (regenerable from MJCF in <1s)
# =============================================
# Generated by scripts/training/mujoco_static_label_map.py and
# scripts/training/mujoco_clean_heightmap.py. See TRAINING.md for the
# regeneration recipe.
**/mujoco/*_gtlabel.npy
**/mujoco/*_gtlabel.json
**/mujoco/*_heightmap.npy
**/mujoco/*_heightmap.json

# =============================================
# IMU calibration (machine-specific)
# =============================================
imu_calib_data.yaml*

