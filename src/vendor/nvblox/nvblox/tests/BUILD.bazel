load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")
load("@rules_cuda//cuda:defs.bzl", "cuda_library", "cuda_test")

alias(
    name = "test_data",
    actual = "//executables/tests:test_data",
    visibility = ["//visibility:public"],
)

# Side-steps cuda_library's lack of `strip_include_prefix` support.
# See: https://github.com/bazel-contrib/rules_cuda/issues/142
cc_library(
    name = "test_lib_cu_headers",
    hdrs = [
        "include/nvblox/tests/blox.h",
        "include/nvblox/tests/blox_utils.h",
        "include/nvblox/tests/custom_camera_sensor.h",
        "include/nvblox/tests/gpu_image_routines.h",
        "include/nvblox/tests/gpu_indexing.h",
        "include/nvblox/tests/gpu_layer_utils.h",
        "include/nvblox/tests/increment_on_gpu.h",
        "include/nvblox/tests/interpolation_2d_gpu.h",
        "include/nvblox/tests/mesh_utils.h",
        "include/nvblox/tests/projective_tsdf_integrator_cuda_components.h",
        "include/nvblox/tests/test_utils_cuda.h",
        "include/nvblox/tests/voxels.h",
        "include/nvblox/tests/weighting_utils.h",
    ],
    includes = ["include"],
    strip_include_prefix = "include",
    visibility = ["//visibility:public"],
)

cuda_library(
    name = "test_lib_cu",
    srcs = [
        "lib/cuda/blox_utils.cu",
        "lib/cuda/boolean_layer_specialization.cu",
        "lib/cuda/float_layer_specialization.cu",
        "lib/cuda/gpu_image_routines.cu",
        "lib/cuda/gpu_indexing.cu",
        "lib/cuda/gpu_layer_utils.cu",
        "lib/cuda/increment_kernel.cu",
        "lib/cuda/index_layer_specialization.cu",
        "lib/cuda/initialization_test_layer_specialization.cu",
        "lib/cuda/interpolation_2d_gpu.cu",
        "lib/cuda/layer.cu",
        "lib/cuda/mesh_utils.cu",
        "lib/cuda/projective_tsdf_integrator_cuda_components.cu",
        "lib/cuda/test_layer.cu",
        "lib/cuda/test_utils_cuda.cu",
        "lib/cuda/weighting_utils.cu",
        "lib/custom_camera_sensor_inst.cu",
    ],
    copts = [
        "--expt-relaxed-constexpr",
        "--extended-lambda",
        # Warning flags are configured globally in .bazelrc
        "--compiler-options=-fPIC",
    ],
    defines = ["STBI_NO_FAILURE_STRINGS"],
    includes = ["include"],
    visibility = ["//visibility:public"],
    deps = [
        ":test_lib_cu_headers",
        "//nvblox/src:nvblox_lib",
        "@cuda//:thrust",
    ],
)

cc_library(
    name = "test_lib",
    srcs = [
        "lib/esdf_integrator_cpu.cpp",
        "lib/integrator_utils.cpp",
        "lib/projective_tsdf_integrator_cpu.cpp",
        "lib/ransac_plane_fitter_utils.cpp",
        "lib/tsdf_zero_crossings_extractor_cpu.cpp",
        "lib/utils.cpp",
    ],
    hdrs = [
        "include/nvblox/tests/esdf_integrator_cpu.h",
        "include/nvblox/tests/integrator_utils.h",
        "include/nvblox/tests/projective_tsdf_integrator_cpu.h",
        "include/nvblox/tests/ransac_plane_fitter_utils.h",
        "include/nvblox/tests/sensor_fixture.h",
        "include/nvblox/tests/tsdf_zero_crossings_extractor_cpu.h",
        "include/nvblox/tests/utils.h",
    ],
    copts = [
        "-Wno-sign-compare",
        "-Wno-pessimizing-move",
    ],
    defines = [
        "STBI_NO_FAILURE_STRINGS",
        "USE_BAZEL_RUNFILES",
    ],
    includes = ["include"],
    strip_include_prefix = "include",
    visibility = ["//visibility:public"],
    deps = [
        "//nvblox/include:nvblox_headers",
        "//nvblox/src:nvblox_lib",
        "@bazel_tools//tools/cpp/runfiles",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)


genrule(
    name = "convert_regression_test_query_after_clear_to_cpp",
    srcs = ["regression_test_query_after_clear.cu"],
    outs = ["regression_test_query_after_clear.cu.cpp"],
    cmd = "cp $(SRCS) $(OUTS)",
)

cuda_test(
    name = "regression_test_query_after_clear",
    srcs = ["regression_test_query_after_clear.cu.cpp"],
    copts = [
        "--expt-relaxed-constexpr",
        "--extended-lambda",
        "--disable-warnings",
        "--diag-suppress=20012",
    ],
    defines = [
        "STBI_NO_FAILURE_STRINGS",
        "USE_BAZEL_RUNFILES",
    ],
    includes = ["include"],
    visibility = ["//visibility:public"],
    deps = [
        "//nvblox/include:nvblox_headers",
        "//nvblox/src:nvblox_lib",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
        "@rules_cuda//cuda:runtime",
    ],
)

# Non-cuda tests
